import 'dart:async';
import 'dart:ui';
import 'package:flutter/material.dart';
import 'package:flutter/services.dart';
import 'package:google_maps_flutter/google_maps_flutter.dart';
import 'package:geolocator/geolocator.dart';
import '../../config/page_transitions.dart';
import '../../config/map_styles.dart';
import 'driver_earnings_screen.dart';
import 'driver_settings_screen.dart';
import 'driver_online_screen.dart';
import 'driver_menu_screen.dart';
import 'driver_inbox_screen.dart';

// ═══════════════════════════════════════════════════════════════
//  CRUISE DRIVER — HOME / OFFLINE SCREEN
//  Uber Driver–style layout: GO button, floating icons, status bar
// ═══════════════════════════════════════════════════════════════

class DriverHomeScreen extends StatefulWidget {
  const DriverHomeScreen({super.key});
  @override
  State<DriverHomeScreen> createState() => _DriverHomeScreenState();
}

class _DriverHomeScreenState extends State<DriverHomeScreen>
    with TickerProviderStateMixin {

  // ── Brand ──
  static const _gold      = Color(0xFFD4A843);
  static const _goldLight = Color(0xFFF5D990);

  // ── Map ──
  GoogleMapController? _mapCtrl;
  LatLng? _pos;
  double _heading = 0;
  BitmapDescriptor? _arrowIcon;
  StreamSubscription<Position>? _posStream;
  bool _lastStyleDark = true; // track current map style

  // ── Session stats ──
  double _todayEarnings = 0.0;
  int    _todayTrips    = 0;
  double _todayHours    = 0.0;
  final double _rating  = 4.92;

  // ── Animations ──
  late AnimationController _goPulse;
  late Animation<double>   _goPulseVal;
  late AnimationController _fadeIn;
  late Animation<double>   _fadeVal;

  // ═══════════════════════════════════════════════════
  //  LIFECYCLE
  // ═══════════════════════════════════════════════════
  @override
  void initState() {
    super.initState();

    _goPulse = AnimationController(
        vsync: this, duration: const Duration(milliseconds: 2400))
      ..repeat(reverse: true);
    _goPulseVal = Tween<double>(begin: 0.25, end: 1.0)
        .animate(CurvedAnimation(parent: _goPulse, curve: Curves.easeInOut));

    _fadeIn = AnimationController(
        vsync: this, duration: const Duration(milliseconds: 700))
      ..forward();
    _fadeVal = CurvedAnimation(parent: _fadeIn, curve: Curves.easeOut);

    _buildArrowIcon();
    _initLocation();
  }

  @override
  void dispose() {
    _goPulse.dispose();
    _fadeIn.dispose();
    _posStream?.cancel();
    _mapCtrl?.dispose();
    super.dispose();
  }

  // ═══════════════════════════════════════════════════
  //  LOCATION
  // ═══════════════════════════════════════════════════
  Future<void> _initLocation() async {
    try {
      if (!await Geolocator.isLocationServiceEnabled()) return;
      var p = await Geolocator.checkPermission();
      if (p == LocationPermission.denied) {
        p = await Geolocator.requestPermission();
        if (p == LocationPermission.denied) return;
      }
      if (p == LocationPermission.deniedForever) return;

      final last = await Geolocator.getLastKnownPosition();
      if (last != null && mounted) {
        setState(() => _pos = LatLng(last.latitude, last.longitude));
      }
      final cur = await Geolocator.getCurrentPosition(
        locationSettings: const LocationSettings(
          accuracy: LocationAccuracy.high, timeLimit: Duration(seconds: 15)),
      );
      if (!mounted) return;
      setState(() => _pos = LatLng(cur.latitude, cur.longitude));
      _mapCtrl?.animateCamera(CameraUpdate.newLatLng(_pos!));
      _startPosStream();
    } catch (_) {}
  }

  // ── Arrow marker (Canvas-painted gold navigation chevron) ──
  Future<void> _buildArrowIcon() async {
    const double s = 48;
    final recorder = PictureRecorder();
    final canvas = Canvas(recorder, const Rect.fromLTWH(0, 0, s, s));
    canvas.translate(s / 2, s / 2);

    // Outer glow
    canvas.drawCircle(Offset.zero, s * 0.28, Paint()
      ..color = _gold.withOpacity(0.18)
      ..maskFilter = const MaskFilter.blur(BlurStyle.normal, 6));

    // Arrow pointing UP (Marker.rotation handles actual direction)
    final arrow = Path()
      ..moveTo(0, -s * 0.34)
      ..lineTo(s * 0.22, s * 0.20)
      ..quadraticBezierTo(0, s * 0.08, -s * 0.22, s * 0.20)
      ..close();

    // Drop shadow
    canvas.drawPath(arrow.shift(const Offset(0.8, 1.2)), Paint()
      ..color = const Color(0x60000000)
      ..maskFilter = const MaskFilter.blur(BlurStyle.normal, 2));

    // Gradient fill
    final rect = arrow.getBounds();
    canvas.drawPath(arrow, Paint()
      ..shader = LinearGradient(
        begin: Alignment.topCenter, end: Alignment.bottomCenter,
        colors: [_goldLight, _gold],
      ).createShader(rect));

    // White border
    canvas.drawPath(arrow, Paint()
      ..color = Colors.white.withOpacity(0.75)
      ..style = PaintingStyle.stroke
      ..strokeWidth = 1.2
      ..strokeJoin = StrokeJoin.round);

    final picture = recorder.endRecording();
    final image = await picture.toImage(s.toInt(), s.toInt());
    final byteData = await image.toByteData(format: ImageByteFormat.png);
    if (byteData != null && mounted) {
      setState(() => _arrowIcon = BitmapDescriptor.bytes(byteData.buffer.asUint8List()));
    }
  }

  void _startPosStream() {
    _posStream = Geolocator.getPositionStream(
      locationSettings: const LocationSettings(
        accuracy: LocationAccuracy.high, distanceFilter: 3),
    ).listen((pos) {
      if (!mounted) return;
      setState(() {
        _pos = LatLng(pos.latitude, pos.longitude);
        _heading = pos.heading;
      });
      // Auto-center camera on driver arrow
      _mapCtrl?.animateCamera(CameraUpdate.newCameraPosition(
        CameraPosition(target: _pos!, zoom: 15.5, bearing: _heading)));
    }, onError: (_) {});
  }

  Set<Marker> get _driverMarkers {
    if (_arrowIcon == null || _pos == null) return {};
    return {
      Marker(
        markerId: const MarkerId('driver'),
        position: _pos!,
        icon: _arrowIcon!,
        rotation: _heading,
        anchor: const Offset(0.5, 0.5),
        flat: true,
        zIndex: 100,
      ),
    };
  }

  // ═══════════════════════════════════════════════════
  //  GO ONLINE → navigate to DriverOnlineScreen
  // ═══════════════════════════════════════════════════
  Future<void> _goOnline(Color transitionBg) async {
    HapticFeedback.heavyImpact();
    final result = await Navigator.of(context).push<Map<String, dynamic>>(
      PageRouteBuilder(
        opaque: true,
        pageBuilder: (_, __, ___) => DriverOnlineScreen(
          initialPos: _pos, initialHeading: _heading),
        transitionDuration: const Duration(milliseconds: 350),
        reverseTransitionDuration: const Duration(milliseconds: 300),
        transitionsBuilder: (_, anim, __, child) {
          // Theme-aware backdrop prevents flash during transition
          return Stack(children: [
            Container(color: transitionBg),
            FadeTransition(
              opacity: CurvedAnimation(parent: anim, curve: Curves.easeOut),
              child: child),
          ]);
        },
      ),
    );
    if (result != null && mounted) {
      setState(() {
        _todayEarnings += (result['earnings'] as num?)?.toDouble() ?? 0;
        _todayTrips += (result['trips'] as num?)?.toInt() ?? 0;
        _todayHours += (result['hours'] as num?)?.toDouble() ?? 0;
      });
    }
  }

  // ═══════════════════════════════════════════════════
  //  BUILD — Uber Driver offline layout
  // ═══════════════════════════════════════════════════
  @override
  Widget build(BuildContext context) {
    final top = MediaQuery.of(context).padding.top;
    final bot = MediaQuery.of(context).padding.bottom;
    final isDark = Theme.of(context).brightness == Brightness.dark;

    // Adapt status bar icons to theme
    SystemChrome.setSystemUIOverlayStyle(SystemUiOverlayStyle(
      statusBarColor: Colors.transparent,
      statusBarIconBrightness: isDark ? Brightness.light : Brightness.dark,
    ));

    // Live-switch map style when theme changes
    _applyMapStyle(isDark);

    // Theme-aware colors
    final scaffoldBg = isDark ? Colors.black : const Color(0xFFF2F2F7);
    final surface    = isDark ? const Color(0xFF111111) : Colors.white;
    final fabBg      = isDark
        ? const Color(0xFF1A1A1A).withValues(alpha: 0.75)
        : Colors.white.withValues(alpha: 0.85);
    final fabBorder  = isDark
        ? Colors.white.withValues(alpha: 0.06)
        : Colors.black.withValues(alpha: 0.06);
    final fabIcon    = isDark
        ? Colors.white.withValues(alpha: 0.8)
        : Colors.black.withValues(alpha: 0.65);
    final pillBg     = isDark
        ? const Color(0xFF1A1A1A).withValues(alpha: 0.85)
        : Colors.white.withValues(alpha: 0.9);
    final pillBorder = fabBorder;
    final pillText   = isDark ? Colors.white : const Color(0xFF1C1C1E);
    final barBorder  = fabBorder;
    final mutedIcon  = isDark
        ? Colors.white.withValues(alpha: 0.45)
        : Colors.black.withValues(alpha: 0.35);
    final mutedText  = isDark
        ? Colors.white.withValues(alpha: 0.5)
        : Colors.black.withValues(alpha: 0.45);
    final tabInactive = isDark
        ? Colors.white.withValues(alpha: 0.35)
        : Colors.black.withValues(alpha: 0.30);
    final dividerC   = fabBorder;
    final transitionBg = isDark ? Colors.black : const Color(0xFFF2F2F7);

    return Scaffold(
      backgroundColor: scaffoldBg,
      body: Stack(children: [
        // ── Full-screen map ──
        _map(isDark),

        // ── Top-left: Home/Menu button ──
        Positioned(
          top: top + 10, left: 16,
          child: FadeTransition(opacity: _fadeVal,
            child: _fab(Icons.home_rounded, 48, fabBg, fabBorder, fabIcon, () {
              Navigator.of(context).push(
                slideFromRightRoute(const DriverMenuScreen()));
            })),
        ),

        // ── Top-center: Earnings pill ──
        Positioned(
          top: top + 10, left: 0, right: 0,
          child: FadeTransition(opacity: _fadeVal,
            child: Center(child: _earningsPill(pillBg, pillBorder, pillText))),
        ),

        // ── Bottom-left: Stacked action buttons ──
        Positioned(
          bottom: 104 + bot + 110, left: 16,
          child: FadeTransition(opacity: _fadeVal, child: Column(children: [
            _fab(Icons.tune_rounded, 44, fabBg, fabBorder, fabIcon, () {
              Navigator.of(context).push(slideFromRightRoute(const DriverSettingsScreen()));
            }),
            const SizedBox(height: 10),
            _fab(Icons.shield_outlined, 44, fabBg, fabBorder, fabIcon,
                () => _snack('Safety features')),
          ])),
        ),

        // ── Bottom-right: Stacked action buttons ──
        Positioned(
          bottom: 104 + bot + 110, right: 16,
          child: FadeTransition(opacity: _fadeVal, child: Column(children: [
            _fab(Icons.campaign_rounded, 44, fabBg, fabBorder, fabIcon,
                () => _snack('Promotions coming soon')),
            const SizedBox(height: 10),
            _fab(Icons.bar_chart_rounded, 44, fabBg, fabBorder, fabIcon, () {
              Navigator.of(context).push(slideFromRightRoute(const DriverEarningsScreen()));
            }),
          ])),
        ),

        // ── Center: GO button ──
        Positioned(
          bottom: 104 + bot + 16, left: 0, right: 0,
          child: FadeTransition(opacity: _fadeVal, child: Center(child: _goButton(transitionBg))),
        ),

        // ── Bottom status bar ──
        Positioned(
          bottom: 0, left: 0, right: 0,
          child: FadeTransition(opacity: _fadeVal,
            child: _bottomBar('You\'re offline', surface, barBorder, mutedIcon,
                mutedText, tabInactive, dividerC)),
        ),
      ]),
    );
  }

  // ═══════════════════════════════════════════════════
  //  MAP
  // ═══════════════════════════════════════════════════
  void _applyMapStyle(bool isDark) {
    if (_mapCtrl == null) return;
    if (isDark == _lastStyleDark) return; // no change
    _lastStyleDark = isDark;
    try {
      _mapCtrl!.setMapStyle(isDark ? MapStyles.dark : MapStyles.light);
    } catch (_) {}
  }

  Widget _map(bool isDark) {
    final loadBg = isDark ? const Color(0xFF242426) : const Color(0xFFE8E8ED);
    if (_pos == null) {
      return Container(color: loadBg,
        child: const Center(child: CircularProgressIndicator(color: _gold, strokeWidth: 2)));
    }
    return RepaintBoundary(
      child: GoogleMap(
        initialCameraPosition: CameraPosition(
          target: _pos!, zoom: 15.5, bearing: _heading),
        onMapCreated: (c) {
          _mapCtrl = c;
          _lastStyleDark = isDark;
          try { c.setMapStyle(isDark ? MapStyles.dark : MapStyles.light); } catch (_) {}
        },
        markers: _driverMarkers,
        myLocationEnabled: false,
        myLocationButtonEnabled: false,
        zoomControlsEnabled: false,
        mapToolbarEnabled: false,
        compassEnabled: false,
        buildingsEnabled: false,
        trafficEnabled: false,
        indoorViewEnabled: false,
        padding: EdgeInsets.only(
          top: MediaQuery.of(context).padding.top + 70, bottom: 200),
      ),
    );
  }

  // ═══════════════════════════════════════════════════
  //  EARNINGS PILL (Uber-style dark pill at top center)
  // ═══════════════════════════════════════════════════
  Widget _earningsPill(Color bg, Color border, Color text) {
    return ClipRRect(
      borderRadius: BorderRadius.circular(20),
      child: BackdropFilter(
        filter: ImageFilter.blur(sigmaX: 12, sigmaY: 12),
        child: Container(
          padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
          decoration: BoxDecoration(
            color: bg,
            borderRadius: BorderRadius.circular(20),
            border: Border.all(color: border),
          ),
          child: Text(
            '\$${_todayEarnings.toStringAsFixed(2)}',
            style: TextStyle(
              color: text, fontSize: 17,
              fontWeight: FontWeight.w800,
              fontFeatures: const [FontFeature.tabularFigures()],
            ),
          ),
        ),
      ),
    );
  }

  // ═══════════════════════════════════════════════════
  //  GO BUTTON (Uber-style large circle)
  // ═══════════════════════════════════════════════════
  Widget _goButton(Color transitionBg) {
    return GestureDetector(
      onTap: () => _goOnline(transitionBg),
      child: AnimatedBuilder(
        animation: _goPulseVal,
        builder: (_, child) => Container(
          width: 82, height: 82,
          decoration: BoxDecoration(
            shape: BoxShape.circle,
            boxShadow: [
              BoxShadow(
                color: _gold.withValues(alpha: 0.35 * _goPulseVal.value),
                blurRadius: 28 * _goPulseVal.value,
                spreadRadius: 4 * _goPulseVal.value,
              ),
            ],
          ),
          child: child,
        ),
        child: Container(
          width: 82, height: 82,
          decoration: BoxDecoration(
            shape: BoxShape.circle,
            gradient: LinearGradient(
              begin: Alignment.topCenter, end: Alignment.bottomCenter,
              colors: [_gold, _gold.withValues(alpha: 0.85)],
            ),
            border: Border.all(color: _goldLight.withValues(alpha: 0.3), width: 2),
          ),
          child: const Center(
            child: Text('GO',
              style: TextStyle(
                color: Colors.black, fontSize: 28,
                fontWeight: FontWeight.w900, letterSpacing: 2),
            ),
          ),
        ),
      ),
    );
  }

  // ═══════════════════════════════════════════════════
  //  BOTTOM STATUS BAR + TAB BAR (Uber-style)
  // ═══════════════════════════════════════════════════
  Widget _bottomBar(String status, Color surface, Color barBorder,
      Color mutedIcon, Color mutedText, Color tabInactive, Color dividerC) {
    return Container(
      decoration: BoxDecoration(
        color: surface,
        border: Border(top: BorderSide(color: barBorder)),
      ),
      child: SafeArea(
        top: false,
        child: Column(mainAxisSize: MainAxisSize.min, children: [
          // ── "You're offline" status row ──
          SizedBox(
            height: 46,
            child: Row(children: [
              const SizedBox(width: 16),
              GestureDetector(
                onTap: () {
                  HapticFeedback.lightImpact();
                  Navigator.of(context).push(slideFromRightRoute(const DriverSettingsScreen()));
                },
                child: Icon(Icons.tune_rounded, color: mutedIcon, size: 22),
              ),
              const Spacer(),
              Text(status, style: TextStyle(
                color: mutedText,
                fontSize: 14, fontWeight: FontWeight.w600)),
              const Spacer(),
              GestureDetector(
                onTap: () {
                  HapticFeedback.lightImpact();
                  Navigator.of(context).push(
                    slideFromRightRoute(const DriverMenuScreen()));
                },
                child: Icon(Icons.format_list_bulleted_rounded,
                    color: mutedIcon, size: 22),
              ),
              const SizedBox(width: 16),
            ]),
          ),

          // ── Divider ──
          Divider(height: 1, color: dividerC),

          // ── Bottom tab bar (Home, Earnings, Inbox, Menu) ──
          SizedBox(
            height: 56,
            child: Row(
              mainAxisAlignment: MainAxisAlignment.spaceAround,
              children: [
                _tabItem(Icons.home_filled, 'Home', true, tabInactive, () {}),
                _tabItem(Icons.bar_chart_rounded, 'Earnings', false, tabInactive, () {
                  Navigator.of(context).push(
                    slideFromRightRoute(const DriverEarningsScreen()));
                }),
                _tabItem(Icons.mail_outline_rounded, 'Inbox', false, tabInactive, () {
                  Navigator.of(context).push(
                    slideFromRightRoute(const DriverInboxScreen()));
                }),
                _tabItem(Icons.menu_rounded, 'Menu', false, tabInactive, () {
                  Navigator.of(context).push(
                    slideFromRightRoute(const DriverMenuScreen()));
                }),
              ],
            ),
          ),
        ]),
      ),
    );
  }

  Widget _tabItem(IconData icon, String label, bool active, Color inactive, VoidCallback onTap) {
    final color = active ? _gold : inactive;
    return GestureDetector(
      onTap: () { HapticFeedback.lightImpact(); onTap(); },
      behavior: HitTestBehavior.opaque,
      child: SizedBox(
        width: 64,
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Icon(icon, color: color, size: 24),
            const SizedBox(height: 3),
            Text(label, style: TextStyle(
                color: color, fontSize: 10, fontWeight: FontWeight.w600)),
          ],
        ),
      ),
    );
  }

  // ═══════════════════════════════════════════════════
  //  FLOATING ACTION BUTTON
  // ═══════════════════════════════════════════════════
  Widget _fab(IconData icon, double size, Color bg, Color border, Color iconColor, VoidCallback tap) {
    return GestureDetector(
      onTap: () { HapticFeedback.lightImpact(); tap(); },
      child: ClipOval(
        child: BackdropFilter(
          filter: ImageFilter.blur(sigmaX: 10, sigmaY: 10),
          child: Container(
            width: size, height: size,
            decoration: BoxDecoration(
              color: bg,
              shape: BoxShape.circle,
              border: Border.all(color: border),
            ),
            child: Icon(icon, color: iconColor, size: size * 0.44),
          ),
        ),
      ),
    );
  }

  void _snack(String s) {
    ScaffoldMessenger.of(context).showSnackBar(SnackBar(
      content: Text(s, style: const TextStyle(color: Colors.black, fontWeight: FontWeight.w700)),
      backgroundColor: _gold, behavior: SnackBarBehavior.floating,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)),
      duration: const Duration(seconds: 2),
    ));
  }

}
